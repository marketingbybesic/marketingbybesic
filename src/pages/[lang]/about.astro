---
import LayoutAuthority from '@/layouts/LayoutAuthority.astro';
import { getTranslations } from '@/i18n/utils';

export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'es' } },
    { params: { lang: 'it' } },
    { params: { lang: 'hr' } },
  ];
}
const { lang } = Astro.params;
const t = getTranslations(lang);
---

<LayoutAuthority title="About | Marketing by Besic" lang={lang}>
  <!-- Section 1: Our Identity -->
  <section id="our-identity" class="py-20 md:py-32">
    <div class="container-custom">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="heading-xl mb-8">{t.about.heroTitle}</h1>
          <p class="body-lg mb-6">{t.about.heroDesc1}</p>
          <p class="body-md mb-6">{t.about.heroDesc2}</p>
          <p class="body-md">{t.about.heroDesc3}</p>
        </div>
        <div class="rounded-xl overflow-hidden" style="height: 500px;">
          <img
            src="/about-team-photo.webp"
            alt={t.about.teamPhotoAlt}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Our Philosophy -->
  <section id="our-philosophy" class="py-20 md:py-32 bg-bg-secondary">
    <div class="container-custom max-w-4xl">
      <div class="text-center mb-16">
        <h2 class="heading-lg mb-6">{t.about.philosophyTitle}</h2>
        <p class="body-lg max-w-2xl mx-auto">{t.about.philosophyDesc}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-bg-primary border border-white/5 rounded-xl p-8">
          <div class="w-12 h-12 bg-brand/10 rounded-lg flex items-center justify-center mb-4">
            <span class="text-brand text-xl font-bold">01</span>
          </div>
          <h3 class="font-heading text-lg font-bold mb-3">{t.about.philosophy1Title}</h3>
          <p class="body-md">{t.about.philosophy1Desc}</p>
        </div>
        <div class="bg-bg-primary border border-white/5 rounded-xl p-8">
          <div class="w-12 h-12 bg-brand/10 rounded-lg flex items-center justify-center mb-4">
            <span class="text-brand text-xl font-bold">02</span>
          </div>
          <h3 class="font-heading text-lg font-bold mb-3">{t.about.philosophy2Title}</h3>
          <p class="body-md">{t.about.philosophy2Desc}</p>
        </div>
      </div>
      <div class="mt-16 text-center">
        <a href={`/${lang}/contact`} class="btn-primary">{t.about.ctaButton}</a>
      </div>
    </div>
  </section>
</LayoutAuthority>
