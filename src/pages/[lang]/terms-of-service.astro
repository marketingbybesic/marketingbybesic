---
import LayoutAuthority from '@/layouts/LayoutAuthority.astro';
import { getTranslations } from '@/i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'es' } },
    { params: { lang: 'it' } },
    { params: { lang: 'hr' } },
  ];
}

const { lang } = Astro.params;
const t = getTranslations(lang);
---

<LayoutAuthority title={t.termsOfService.pageTitle} lang={lang}>
  <section class="min-h-screen py-20 md:py-32">
    <div class="container-custom max-w-3xl">
      <h1 class="heading-xl mb-12">{t.termsOfService.title}</h1>

      <div class="prose prose-lg prose-invert max-w-none space-y-8">
        <p class="body-md">
          <strong>{t.termsOfService.lastUpdated}:</strong> {t.termsOfService.lastUpdatedDate}
        </p>

        <section>
          <h2 class="heading-md mb-4">{t.termsOfService.section1Heading}</h2>
          <p class="body-md">{t.termsOfService.section1Body}</p>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.termsOfService.section2Heading}</h2>
          <p class="body-md">{t.termsOfService.section2Body}</p>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.termsOfService.section3Heading}</h2>
          <p class="body-md">{t.termsOfService.section3Intro}</p>
          <ul class="list-disc list-inside body-md space-y-1">
            <li>{t.termsOfService.section3Item1}</li>
            <li>{t.termsOfService.section3Item2}</li>
            <li>{t.termsOfService.section3Item3}</li>
            <li>{t.termsOfService.section3Item4}</li>
          </ul>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.termsOfService.section4Heading}</h2>
          <p class="body-md">{t.termsOfService.section4Body}</p>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.termsOfService.section5Heading}</h2>
          <p class="body-md">{t.termsOfService.section5Body}</p>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.termsOfService.section6Heading}</h2>
          <p class="body-md">{t.termsOfService.section6Body}</p>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.termsOfService.section7Heading}</h2>
          <p class="body-md">{t.termsOfService.section7Body}</p>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.termsOfService.section8Heading}</h2>
          <p class="body-md">{t.termsOfService.section8Body}</p>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.termsOfService.section9Heading}</h2>
          <p class="body-md">
            {t.termsOfService.section9Body} <a href="mailto:info@marketingbybesic.com" class="text-brand hover:underline">info@marketingbybesic.com</a>.
          </p>
        </section>
      </div>
    </div>
  </section>
</LayoutAuthority>
