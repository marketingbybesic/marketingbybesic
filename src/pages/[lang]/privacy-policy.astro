---
import LayoutAuthority from '@/layouts/LayoutAuthority.astro';
import { getTranslations } from '@/i18n/utils';

export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'es' } },
    { params: { lang: 'it' } },
    { params: { lang: 'hr' } },
  ];
}

const { lang } = Astro.params;
const t = getTranslations(lang);
---

<LayoutAuthority title={t.privacyPolicy.pageTitle} lang={lang}>
  <section class="min-h-screen py-20 md:py-32">
    <div class="container-custom max-w-3xl">
      <h1 class="heading-xl mb-12">{t.privacyPolicy.title}</h1>

      <div class="prose prose-lg prose-invert max-w-none space-y-8">
        <p class="body-md">
          <strong>{t.privacyPolicy.lastUpdated}:</strong> {t.privacyPolicy.lastUpdatedDate}
        </p>

        <section>
          <h2 class="heading-md mb-4">{t.privacyPolicy.section1Heading}</h2>
          <p class="body-md">{t.privacyPolicy.section1Body}</p>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.privacyPolicy.section2Heading}</h2>
          <p class="body-md">{t.privacyPolicy.section2Intro}</p>
          <ul class="list-disc list-inside body-md space-y-1">
            <li>{t.privacyPolicy.section2Item1}</li>
            <li>{t.privacyPolicy.section2Item2}</li>
            <li>{t.privacyPolicy.section2Item3}</li>
          </ul>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.privacyPolicy.section3Heading}</h2>
          <p class="body-md">{t.privacyPolicy.section3Body}</p>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.privacyPolicy.section4Heading}</h2>
          <p class="body-md">{t.privacyPolicy.section4Intro}</p>
          <ul class="list-disc list-inside body-md space-y-1">
            <li><strong>SendFox:</strong> {t.privacyPolicy.section4Item1.replace('SendFox: ', '')}</li>
            <li><strong>Google Tag Manager (GTM-5GL56SKX):</strong> {t.privacyPolicy.section4Item2.replace('Google Tag Manager (GTM-5GL56SKX): ', '')}</li>
            <li><strong>Meta Pixel (1978765049417651):</strong> {t.privacyPolicy.section4Item3.replace('Meta Pixel (1978765049417651): ', '')}</li>
          </ul>
          <p class="body-md mt-4">{t.privacyPolicy.section4Footer}</p>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.privacyPolicy.section5Heading}</h2>
          <p class="body-md">{t.privacyPolicy.section5Intro}</p>
          <ul class="list-disc list-inside body-md space-y-1">
            <li>{t.privacyPolicy.section5Item1}</li>
            <li>{t.privacyPolicy.section5Item2}</li>
            <li>{t.privacyPolicy.section5Item3}</li>
            <li>{t.privacyPolicy.section5Item4}</li>
            <li>{t.privacyPolicy.section5Item5}</li>
          </ul>
          <p class="body-md mt-4">
            {t.privacyPolicy.section5Footer} <a href="mailto:info@marketingbybesic.com" class="text-brand hover:underline">info@marketingbybesic.com</a>.
          </p>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.privacyPolicy.section6Heading}</h2>
          <p class="body-md">{t.privacyPolicy.section6Body}</p>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.privacyPolicy.section7Heading}</h2>
          <p class="body-md">
            {t.privacyPolicy.section7Body} <a href="mailto:info@marketingbybesic.com" class="text-brand hover:underline">info@marketingbybesic.com</a>.
          </p>
        </section>
      </div>
    </div>
  </section>
</LayoutAuthority>
