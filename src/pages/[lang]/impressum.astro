---
import LayoutAuthority from '@/layouts/LayoutAuthority.astro';
import { getTranslations } from '@/i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'es' } },
    { params: { lang: 'it' } },
    { params: { lang: 'hr' } },
  ];
}

const { lang } = Astro.params;
const t = getTranslations(lang);
---

<LayoutAuthority title={t.impressum.pageTitle} lang={lang}>
  <section class="min-h-screen py-20 md:py-32">
    <div class="container-custom max-w-3xl">
      <h1 class="heading-xl mb-12">{t.impressum.title}</h1>

      <div class="prose prose-lg prose-invert max-w-none space-y-8">
        <section>
          <h2 class="heading-md mb-4">{t.impressum.legalNoticeHeading}</h2>
          <div class="body-md space-y-1">
            <p><strong>{t.impressum.companyLabel}:</strong> BEŠIĆ j.d.o.o. za usluge</p>
            <p><strong>{t.impressum.addressLabel}:</strong> Zagreb, Croatia</p>
            <p><strong>{t.impressum.managementLabel}:</strong> Dino Bešić</p>
            <p><strong>{t.impressum.emailLabel}:</strong> <a href="mailto:info@marketingbybesic.com" class="text-brand hover:underline">info@marketingbybesic.com</a></p>
          </div>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.impressum.bankDetailsHeading}</h2>
          <div class="body-md space-y-1">
            <p><strong>IBAN:</strong> HR2624840081135491290</p>
            <p><strong>SWIFT/BIC:</strong> RZBHHR2XXXX</p>
          </div>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.impressum.responsibleHeading}</h2>
          <p class="body-md">{t.impressum.responsibleBody}</p>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.impressum.disputeHeading}</h2>
          <p class="body-md">{t.impressum.disputeBody}</p>
        </section>

        <section>
          <h2 class="heading-md mb-4">{t.impressum.liabilityHeading}</h2>
          <p class="body-md">{t.impressum.liabilityBody}</p>
        </section>
      </div>
    </div>
  </section>
</LayoutAuthority>
