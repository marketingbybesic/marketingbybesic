---
import LayoutAuthority from '../../../layouts/LayoutAuthority.astro';
import { getCollection, render } from 'astro:content';
import { getTranslations } from '../../../i18n/utils';
import type { CollectionEntry } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const locales = ['de', 'fr', 'es', 'it', 'hr'];
  const allArticles = await getCollection('articles');
  const proofPosts = allArticles.filter((a) => a.data.category === 'proof');
  return proofPosts.flatMap((post: CollectionEntry<'articles'>) =>
    locales.map((lang) => ({
      params: { lang, slug: post.id },
      props: { post },
    }))
  );
}

const { lang } = Astro.params;
const { post } = Astro.props;
const t = getTranslations(lang);

const { Content } = await render(post);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<LayoutAuthority
  title={`${post.data.title} | Marketing by Bešić`}
  description={post.data.metaDescription}
  lang={lang}
>
  <article class="py-20 md:py-32">
    <div class="container-custom max-w-3xl">

      <!-- Back link -->
      <a href={`/${lang}/proof`} class="inline-flex items-center gap-2 text-text-secondary hover:text-brand transition-colors text-sm mb-10">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        {t.proof.backToProof}
      </a>

      <!-- Tag + Date -->
      <div class="flex items-center gap-4 mb-6">
        <span class="text-brand text-xs font-semibold tracking-widest uppercase">
          {post.data.tag}
        </span>
        <span class="text-text-secondary text-xs">·</span>
        <time class="text-text-secondary text-xs" datetime={post.data.publishDate.toISOString()}>
          {formatDate(post.data.publishDate)}
        </time>
      </div>

      <!-- Title -->
      <h1 class="heading-lg mb-6">
        {post.data.title}
      </h1>

      <!-- Author -->
      <p class="text-text-secondary text-sm mb-10">
        {t.proof.byAuthor} <span class="text-text-primary font-semibold">{post.data.author}</span>
      </p>

      <!-- Image -->
      {post.data.image && (
        <div class="rounded-xl overflow-hidden mb-12 aspect-video">
          <img
            src={post.data.image}
            alt={post.data.title}
            class="w-full h-full object-cover"
            width="1200"
            height="675"
          />
        </div>
      )}

      <!-- Body -->
      <div class="prose prose-invert max-w-none text-justify
        prose-headings:text-left prose-headings:font-heading prose-headings:font-bold
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-text-secondary prose-p:leading-relaxed prose-p:mb-6
        prose-strong:text-text-primary
        prose-a:text-brand prose-a:no-underline hover:prose-a:underline
        prose-ul:text-text-secondary prose-ol:text-text-secondary
        prose-li:mb-2
        prose-blockquote:border-brand prose-blockquote:text-text-secondary
        prose-hr:border-white/10">
        <Content />
      </div>

      <!-- Back link bottom -->
      <div class="mt-16 pt-8 border-t border-white/10">
        <a href={`/${lang}/proof`} class="inline-flex items-center gap-2 text-text-secondary hover:text-brand transition-colors text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          {t.proof.backToAllArticles}
        </a>
      </div>

    </div>
  </article>

  <!-- CTA Section -->
  <section class="py-16 bg-bg-secondary border-t border-white/5">
    <div class="container-custom max-w-3xl text-center">
      <h2 class="heading-lg mb-4">{t.proof.ctaTitle}</h2>
      <p class="body-lg mb-8">{t.proof.ctaDesc}</p>
      <a href={`/${lang}/contact`} class="btn-primary">{t.proof.ctaButton}</a>
    </div>
  </section>
</LayoutAuthority>
