---
import LayoutAuthority from '@/layouts/LayoutAuthority.astro';
import { getTranslations } from '@/i18n/utils';
import nodemailer from 'nodemailer';

export const prerender = false;

const { lang } = Astro.params;
const supportedLangs = ['en', 'de', 'fr', 'es', 'it', 'hr'];
if (!lang || !supportedLangs.includes(lang)) {
  return Astro.redirect('/en/apply');
}
const t = getTranslations(lang);

let successMessage = "";
let errorMessage = "";

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const name = data.get("name")?.toString() || "Unknown";
    const email = data.get("email")?.toString() || "No Email";
    const company = data.get("company")?.toString() || "";
    const website = data.get("website")?.toString() || "";
    const revenue = data.get("revenue")?.toString() || "";
    const challenge = data.get("challenge")?.toString() || "";
    const tried = data.get("tried")?.toString() || "";
    const budget = data.get("budget")?.toString() || "";
    const timeline = data.get("timeline")?.toString() || "";
    const source = data.get("source")?.toString() || "";

    if (!import.meta.env.SMTP_EMAIL || !import.meta.env.RECEIVER_EMAIL) {
      throw new Error("Server configuration error.");
    }

    const transporter = nodemailer.createTransport({
      host: "smtp.gmail.com",
      port: 465,
      secure: true,
      auth: {
        user: import.meta.env.SMTP_EMAIL,
        pass: import.meta.env.SMTP_PASSWORD,
      },
    });

    await transporter.sendMail({
      from: `"MBB Revenue Diagnosis" <${import.meta.env.SMTP_EMAIL}>`,
      replyTo: email,
      to: import.meta.env.RECEIVER_EMAIL,
      subject: `[APPLY] Revenue Diagnosis: ${company} - ${name}`,
      text: `=== REVENUE DIAGNOSIS APPLICATION ===\n\nName: ${name}\nEmail: ${email}\nCompany: ${company}\nWebsite: ${website}\nAnnual Revenue: ${revenue}\nMonthly Budget: ${budget}\nTimeline: ${timeline}\nSource: ${source}\n\n--- CHALLENGE ---\n${challenge}\n\n--- ALREADY TRIED ---\n${tried}`,
    });

    successMessage = lang === 'hr'
      ? "Prijava uspješno poslana! Javit ćemo Vam se unutar 24 sata."
      : lang === 'de'
      ? "Bewerbung erfolgreich gesendet! Wir melden uns innerhalb von 24 Stunden."
      : "Application submitted successfully! We'll get back to you within 24 hours.";
  } catch (error) {
    console.error("[APPLY FORM] ERROR:", error);
    errorMessage = lang === 'hr'
      ? "Došlo je do pogreške. Pokušajte ponovno ili nam pišite na info@marketingbybesic.com."
      : lang === 'de'
      ? "Ein Fehler ist aufgetreten. Bitte versuchen Sie es erneut oder schreiben Sie uns an info@marketingbybesic.com."
      : "There was an error. Please try again or email us at info@marketingbybesic.com.";
  }
}

const base = lang === 'en' ? '' : `/${lang}`;
---

<LayoutAuthority title={`${t.apply.pageTitle} | Marketing by Bešić`} lang={lang}>
  <section class="py-20 md:py-32">
    <div class="container-custom max-w-4xl">

      <!-- Hero -->
      <div class="text-center mb-12">
        <h1 class="heading-xl mb-6">{t.apply.heroTitle}</h1>
        <p class="body-lg max-w-2xl mx-auto">{t.apply.heroDesc}</p>
      </div>

      <!-- Trust bar -->
      <div class="flex flex-wrap justify-center gap-6 mb-12 text-sm text-text-secondary">
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 bg-brand rounded-full"></span>
          {t.apply.trustLine1}
        </span>
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 bg-brand rounded-full"></span>
          {t.apply.trustLine2}
        </span>
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 bg-brand rounded-full"></span>
          {t.apply.trustLine3}
        </span>
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 bg-brand rounded-full"></span>
          {t.apply.trustLine4}
        </span>
      </div>

      <!-- Steps -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-16">
        <div class="bg-bg-secondary border border-white/5 rounded-xl p-5 text-center">
          <div class="text-brand text-2xl font-heading font-bold mb-2">01</div>
          <p class="text-sm text-text-secondary">{t.apply.step1}</p>
        </div>
        <div class="bg-bg-secondary border border-white/5 rounded-xl p-5 text-center">
          <div class="text-brand text-2xl font-heading font-bold mb-2">02</div>
          <p class="text-sm text-text-secondary">{t.apply.step2}</p>
        </div>
        <div class="bg-bg-secondary border border-white/5 rounded-xl p-5 text-center">
          <div class="text-brand text-2xl font-heading font-bold mb-2">03</div>
          <p class="text-sm text-text-secondary">{t.apply.step3}</p>
        </div>
        <div class="bg-bg-secondary border border-white/5 rounded-xl p-5 text-center">
          <div class="text-brand text-2xl font-heading font-bold mb-2">04</div>
          <p class="text-sm text-text-secondary">{t.apply.step4}</p>
        </div>
      </div>

      <!-- Status messages -->
      {successMessage && (
        <div class="mb-8 p-6 rounded-xl bg-green-900/20 border border-green-500/30 text-green-400 text-center text-lg">
          {successMessage}
        </div>
      )}

      {errorMessage && (
        <div class="mb-8 p-6 rounded-xl bg-red-900/20 border border-red-500/30 text-red-400 text-center">
          {errorMessage}
        </div>
      )}

      <!-- Application Form -->
      <form method="POST" class="bg-bg-secondary border border-white/5 rounded-xl p-8 md:p-10 space-y-6">
        <h2 class="heading-md mb-2">{t.apply.formTitle}</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="name" class="block text-sm font-medium text-text-secondary mb-2">{t.apply.nameLabel}</label>
            <input type="text" id="name" name="name" required
              class="w-full px-4 py-3 bg-bg-primary border border-white/10 rounded-lg text-text-primary placeholder:text-text-secondary focus:outline-none focus:border-brand transition-colors"
              placeholder={t.apply.namePlaceholder} />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-text-secondary mb-2">{t.apply.emailLabel}</label>
            <input type="email" id="email" name="email" required
              class="w-full px-4 py-3 bg-bg-primary border border-white/10 rounded-lg text-text-primary placeholder:text-text-secondary focus:outline-none focus:border-brand transition-colors"
              placeholder={t.apply.emailPlaceholder} />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="company" class="block text-sm font-medium text-text-secondary mb-2">{t.apply.companyLabel}</label>
            <input type="text" id="company" name="company" required
              class="w-full px-4 py-3 bg-bg-primary border border-white/10 rounded-lg text-text-primary placeholder:text-text-secondary focus:outline-none focus:border-brand transition-colors"
              placeholder={t.apply.companyPlaceholder} />
          </div>
          <div>
            <label for="website" class="block text-sm font-medium text-text-secondary mb-2">{t.apply.websiteLabel}</label>
            <input type="url" id="website" name="website"
              class="w-full px-4 py-3 bg-bg-primary border border-white/10 rounded-lg text-text-primary placeholder:text-text-secondary focus:outline-none focus:border-brand transition-colors"
              placeholder={t.apply.websitePlaceholder} />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="revenue" class="block text-sm font-medium text-text-secondary mb-2">{t.apply.revenueLabel}</label>
            <select id="revenue" name="revenue" required
              class="w-full px-4 py-3 bg-bg-primary border border-white/10 rounded-lg text-text-primary focus:outline-none focus:border-brand transition-colors">
              <option value="">&mdash;</option>
              <option value="under-500k">{t.apply.revenueOption1}</option>
              <option value="500k-2m">{t.apply.revenueOption2}</option>
              <option value="2m-10m">{t.apply.revenueOption3}</option>
              <option value="10m-plus">{t.apply.revenueOption4}</option>
            </select>
          </div>
          <div>
            <label for="budget" class="block text-sm font-medium text-text-secondary mb-2">{t.apply.budgetLabel}</label>
            <select id="budget" name="budget" required
              class="w-full px-4 py-3 bg-bg-primary border border-white/10 rounded-lg text-text-primary focus:outline-none focus:border-brand transition-colors">
              <option value="">&mdash;</option>
              <option value="under-2k">{t.apply.budgetOption1}</option>
              <option value="2k-5k">{t.apply.budgetOption2}</option>
              <option value="5k-15k">{t.apply.budgetOption3}</option>
              <option value="15k-plus">{t.apply.budgetOption4}</option>
            </select>
          </div>
        </div>

        <div>
          <label for="challenge" class="block text-sm font-medium text-text-secondary mb-2">{t.apply.challengeLabel}</label>
          <textarea id="challenge" name="challenge" rows="3" required
            class="w-full px-4 py-3 bg-bg-primary border border-white/10 rounded-lg text-text-primary placeholder:text-text-secondary focus:outline-none focus:border-brand transition-colors resize-none"
            placeholder={t.apply.challengePlaceholder}></textarea>
        </div>

        <div>
          <label for="tried" class="block text-sm font-medium text-text-secondary mb-2">{t.apply.triedLabel}</label>
          <textarea id="tried" name="tried" rows="2"
            class="w-full px-4 py-3 bg-bg-primary border border-white/10 rounded-lg text-text-primary placeholder:text-text-secondary focus:outline-none focus:border-brand transition-colors resize-none"
            placeholder={t.apply.triedPlaceholder}></textarea>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="timeline" class="block text-sm font-medium text-text-secondary mb-2">{t.apply.timelineLabel}</label>
            <select id="timeline" name="timeline"
              class="w-full px-4 py-3 bg-bg-primary border border-white/10 rounded-lg text-text-primary focus:outline-none focus:border-brand transition-colors">
              <option value="">&mdash;</option>
              <option value="immediately">{t.apply.timelineOption1}</option>
              <option value="2-weeks">{t.apply.timelineOption2}</option>
              <option value="1-month">{t.apply.timelineOption3}</option>
              <option value="exploring">{t.apply.timelineOption4}</option>
            </select>
          </div>
          <div>
            <label for="source" class="block text-sm font-medium text-text-secondary mb-2">{t.apply.sourceLabel}</label>
            <input type="text" id="source" name="source"
              class="w-full px-4 py-3 bg-bg-primary border border-white/10 rounded-lg text-text-primary placeholder:text-text-secondary focus:outline-none focus:border-brand transition-colors"
              placeholder={t.apply.sourcePlaceholder} />
          </div>
        </div>

        <button type="submit" class="btn-primary w-full text-lg py-4">{t.apply.submitButton}</button>

        <p class="text-xs text-text-secondary text-center mt-4">{t.apply.disclaimer}</p>
      </form>

    </div>
  </section>
</LayoutAuthority>
