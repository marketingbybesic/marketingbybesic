---
import LayoutAuthority from '../../layouts/LayoutAuthority.astro';
import OfferPage from '../../components/OfferPage.astro';
import { getTranslations } from '../../i18n/utils';

export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'es' } },
    { params: { lang: 'it' } },
    { params: { lang: 'hr' } },
  ];
}

const { lang } = Astro.params;
const t = getTranslations(lang);

const iconPath = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />';
---

<LayoutAuthority title={`${t.offerFitness.pageTitle} | Marketing by Besic`} lang={lang}>
  <OfferPage
    t={t.offerFitness}
    lang={lang}
    iconPath={iconPath}
    heroImg="/offer-fitness-hero.webp"
    problemImg="/offer-fitness-problem.webp"
    solutionImg="/offer-fitness-solution.webp"
  />
</LayoutAuthority>
