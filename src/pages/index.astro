---
import LayoutAuthority from '../layouts/LayoutAuthority.astro';
import homeData from '../content/pages/home.json';

const { hero, socialProof, problem, nlp, pillars, compounding, ctaSection } = homeData;
---

<LayoutAuthority title="Marketing by Bešić | Neurolinguistic Revenue Architecture">
  <!-- Section 1: Hero -->
  <section id="hero" class="min-h-screen flex items-center justify-center relative overflow-hidden" data-tina-field="hero">
    <!-- Background Glow -->
    <div class="absolute inset-0 bg-gradient-to-b from-brand/5 via-transparent to-transparent"></div>
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-96 h-96 bg-brand/10 rounded-full blur-3xl"></div>

    <div class="container-custom relative z-10 text-center py-20">
      <p class="text-brand text-sm md:text-base font-semibold tracking-widest uppercase mb-6" data-tina-field="hero.eyebrow">
        {hero.eyebrow}
      </p>
      <h1 class="heading-xl max-w-4xl mx-auto mb-8" data-tina-field="hero.heroTitle">
        {hero.heroTitle}
      </h1>
      <p class="body-lg max-w-2xl mx-auto mb-12" data-tina-field="hero.description">
        {hero.description}
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={hero.ctaSecondary?.url ?? '/en/architecture'} class="btn-secondary" data-tina-field="hero.ctaSecondary.label">
          {hero.ctaSecondary?.label ?? 'See How It Works'}
        </a>
        <a href={hero.ctaPrimary?.url ?? '/en/contact'} class="btn-primary" data-tina-field="hero.ctaPrimary.label">
          {hero.ctaPrimary?.label ?? 'Get in Touch'}
        </a>
      </div>
    </div>
  </section>

  <!-- Section 2: The Problem -->
  <section id="the-problem" class="py-20 md:py-32" style="background-color: #111111;" data-tina-field="problem">
    <div class="container-custom">
      <div class="text-center mb-16">
        <h2 class="heading-lg max-w-3xl mx-auto mb-6" data-tina-field="problem.heading">
          {problem.heading}
        </h2>
        <p class="body-lg max-w-2xl mx-auto" data-tina-field="problem.subheading">
          {problem.subheading}
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {problem.cards?.map((card) => (
          <div class="bg-bg-secondary border border-white/5 rounded-xl p-8">
            <div class="w-12 h-12 bg-brand/10 rounded-lg flex items-center justify-center mb-4">
              <span class="text-brand text-xl font-bold">{card.number}</span>
            </div>
            <h3 class="font-heading text-lg font-bold mb-2">
              {card.title}
            </h3>
            <p class="body-md">
              {card.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 4: The NLP Advantage -->
  <section id="the-nlp-advantage" class="py-20 md:py-32" data-tina-field="nlp">
    <div class="container-custom">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="heading-lg mb-6" data-tina-field="nlp.heading">
            {nlp.heading}
          </h2>
          <p class="body-lg mb-6" data-tina-field="nlp.body1">
            {nlp.body1}
          </p>
          <p class="body-md" data-tina-field="nlp.body2">
            {nlp.body2}
          </p>
        </div>
        <div class="bg-bg-secondary border border-white/5 rounded-xl overflow-hidden aspect-square">
          <img
            src="/nlp-framework-visual.webp"
            alt="NLP Framework Visual"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5: The Pillars + CTA (seamless bg-bg-secondary block) -->
  <section id="the-pillars" class="pt-20 md:pt-32 bg-bg-secondary" data-tina-field="pillars">
    <div class="container-custom">
      <div class="text-center mb-16">
        <h2 class="heading-lg max-w-3xl mx-auto mb-6" data-tina-field="pillars.heading">
          {pillars.heading}
        </h2>
        <p class="body-lg max-w-2xl mx-auto" data-tina-field="pillars.subheading">
          {pillars.subheading}
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {pillars.items?.map((pillar) => (
          <div class="bg-bg-primary border border-white/5 rounded-xl p-8 text-center">
            <div class="w-16 h-16 bg-brand/10 rounded-full flex items-center justify-center mx-auto mb-6">
              <span class="text-brand text-2xl font-bold">{pillar.numeral}</span>
            </div>
            <h3 class="font-heading text-xl font-bold mb-3">
              {pillar.title}
            </h3>
            <p class="body-md">
              {pillar.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA — seamlessly continues bg-bg-secondary from pillars section -->
  <section id="final-cta" class="pb-20 md:pb-32 bg-bg-secondary" data-tina-field="ctaSection">
    <div class="container-custom text-center pt-20 md:pt-32">
      <h2 class="heading-lg max-w-3xl mx-auto mb-6" data-tina-field="ctaSection.title">
        {ctaSection.title}
      </h2>
      <p class="body-lg max-w-2xl mx-auto mb-10" data-tina-field="ctaSection.description">
        {ctaSection.description}
      </p>
      <a href={ctaSection.ctaUrl ?? '/en/contact'} class="btn-primary text-lg px-10 py-5" data-tina-field="ctaSection.ctaLabel">
        {ctaSection.ctaLabel}
      </a>
    </div>
  </section>

  <!-- Section 6: The Compounding Effect -->
  <section id="the-compounding-effect" class="py-20 md:py-32" data-tina-field="compounding">
    <div class="container-custom">
      <div class="text-center mb-16">
        <h2 class="heading-lg max-w-3xl mx-auto mb-6" data-tina-field="compounding.heading">
          {compounding.heading}
        </h2>
        <p class="body-lg max-w-2xl mx-auto" data-tina-field="compounding.subheading">
          {compounding.subheading}
        </p>
      </div>
      <div class="max-w-3xl mx-auto">
        <!-- Feedback Loop Visual -->
        <div class="bg-bg-secondary border border-white/5 rounded-xl p-8 md:p-12">
          <div class="flex flex-col md:flex-row items-center justify-between gap-8">
            {compounding.steps?.map((step, i) => (
              <>
                <div class="text-center">
                  <div class="w-16 h-16 bg-brand/10 rounded-full flex items-center justify-center mx-auto mb-4">
                    <span class="text-brand text-xl font-bold">{step.number}</span>
                  </div>
                  <p class="text-sm text-text-secondary">
                    {step.label}
                  </p>
                </div>
                {i < (compounding.steps?.length ?? 0) - 1 && (
                  <div class="text-brand text-2xl hidden md:block">→</div>
                )}
              </>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

</LayoutAuthority>
