---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { getTranslations } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = 'Neurolinguistic Revenue Architecture for Europe\'s Elite Aesthetic Clinics', lang = 'en' } = Astro.props;
const t = getTranslations(lang);

// Build locale-aware nav links
const base = lang === 'en' ? '' : `/${lang}`;
---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Open Graph -->
    <meta property="og:image" content="/og-image.svg" />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    
    <title>{title}</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    </noscript>

    <!-- GTM Head (conditional on GDPR) -->
    <script is:inline>
      (function() {
        var consent = localStorage.getItem('gdpr_consent');
        if (consent === 'accepted') {
          (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
          new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
          j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
          'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer','GTM-5GL56SKX');
        }
      })();
    </script>

    <!-- Meta Pixel Head (conditional on GDPR) -->
    <script is:inline>
      (function() {
        var consent = localStorage.getItem('gdpr_consent');
        if (consent === 'accepted') {
          !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
          n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
          n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
          t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
          document,'script','https://connect.facebook.net/en_US/fbevents.js');
          fbq('init', '1978765049417651');
          fbq('track', 'PageView');
        }
      })();
    </script>
  </head>
  <body class="bg-bg-primary text-text-primary font-body antialiased bg-pattern">
    <!-- GTM Body (noscript) -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5GL56SKX" height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>

    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b border-white/5" style="background-color: #000000;">
      <div class="container-custom">
        <div class="flex items-center justify-between h-16 md:h-20">
          <!-- Logo Animation -->
          <a href={lang === 'en' ? '/' : `/${lang}/`} class="flex items-center gap-3">
            <video autoplay loop muted playsinline class="h-20 w-auto" aria-label="Marketing by Besic Logo Animation">
              <source src="/Logo Animation - Marketing by Besic.webm" type="video/webm">
            </video>
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden md:flex items-center gap-8">
            <a href={`${base}/about`} class="text-text-secondary hover:text-text-primary transition-colors">{t.nav.about}</a>
            <a href={`${base}/architecture`} class="text-text-secondary hover:text-text-primary transition-colors">{t.nav.architecture}</a>
            <a href={`${base}/proof`} class="text-text-secondary hover:text-text-primary transition-colors">{t.nav.proof}</a>
            <a href="/blog" class="text-text-secondary hover:text-text-primary transition-colors">{t.nav.blog}</a>
            <a href={`${base}/contact`} class="text-text-secondary hover:text-text-primary transition-colors">{t.nav.contact}</a>
          </nav>

          <!-- Language Switcher (desktop: full label, mobile: globe only next to hamburger) -->
          <div class="hidden md:block">
            <LanguageSwitcher />
          </div>

          <!-- CTA -->
          <a href={`${base}/contact`} class="hidden md:inline-flex btn-primary text-sm px-6 py-3">
            {t.nav.getInTouch}
          </a>

          <!-- Mobile: Globe + Hamburger -->
          <div class="flex items-center gap-1 md:hidden">
            <LanguageSwitcher mobileOnly={true} />
            <button id="mobile-menu-btn" class="p-2 text-text-primary" aria-label="Toggle menu">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden pb-6">
          <nav class="flex flex-col gap-4">
            <a href={`${base}/about`} class="text-text-secondary hover:text-text-primary transition-colors py-2">{t.nav.about}</a>
            <a href={`${base}/architecture`} class="text-text-secondary hover:text-text-primary transition-colors py-2">{t.nav.architecture}</a>
            <a href={`${base}/proof`} class="text-text-secondary hover:text-text-primary transition-colors py-2">{t.nav.proof}</a>
            <a href="/blog" class="text-text-secondary hover:text-text-primary transition-colors py-2">{t.nav.blog}</a>
            <a href={`${base}/contact`} class="text-text-secondary hover:text-text-primary transition-colors py-2">{t.nav.contact}</a>
            <a href={`${base}/contact`} class="btn-primary text-center mt-2">{t.nav.getInTouch}</a>
          </nav>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="pt-16 md:pt-20">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-bg-secondary border-t border-white/5 py-12 md:py-16">
      <div class="container-custom">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-12">
          <!-- Brand -->
          <div class="md:col-span-2">
            <img src="/logo-text.svg" alt="Marketing by Besic" class="h-8 mb-4" width="200" height="32" />
            <p class="body-md max-w-md">
              Neurolinguistic Revenue Architecture for Europe's elite aesthetic clinics.
            </p>
            <!-- Live Status Indicator -->
            <div class="mt-4 flex items-center gap-2 text-text-secondary text-sm">
              <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
              <span>{t.footer.liveFrom}</span>
              <span id="zagreb-time" class="font-mono"></span>
            </div>
          </div>

          <!-- Quick Links -->
          <div>
            <h4 class="font-semibold text-text-primary mb-4">{t.footer.navigation}</h4>
            <ul class="space-y-2">
              <li><a href={`${base}/about`} class="text-text-secondary hover:text-text-primary transition-colors text-sm">{t.nav.about}</a></li>
              <li><a href={`${base}/architecture`} class="text-text-secondary hover:text-text-primary transition-colors text-sm">{t.nav.architecture}</a></li>
              <li><a href={`${base}/proof`} class="text-text-secondary hover:text-text-primary transition-colors text-sm">{t.nav.proof}</a></li>
              <li><a href="/blog" class="text-text-secondary hover:text-text-primary transition-colors text-sm">{t.nav.blog}</a></li>
              <li><a href={`${base}/contact`} class="text-text-secondary hover:text-text-primary transition-colors text-sm">{t.nav.contact}</a></li>
            </ul>
          </div>

          <!-- Legal -->
          <div>
            <h4 class="font-semibold text-text-primary mb-4">{t.footer.legal}</h4>
            <ul class="space-y-2">
              <li><a href={`${base}/privacy-policy`} class="text-text-secondary hover:text-text-primary transition-colors text-sm">{t.footer.privacyPolicy}</a></li>
              <li><a href={`${base}/terms-of-service`} class="text-text-secondary hover:text-text-primary transition-colors text-sm">{t.footer.termsOfService}</a></li>
              <li><a href={`${base}/impressum`} class="text-text-secondary hover:text-text-primary transition-colors text-sm">{t.footer.impressum}</a></li>
            </ul>
          </div>
        </div>

        <!-- Social Links -->
        <div class="mt-12 pt-8 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-6">
          <p class="text-text-secondary text-sm">
            &copy; {new Date().getFullYear()} Besic j.d.o.o. {t.footer.allRightsReserved} | <a href="mailto:info@marketingbybesic.com" class="text-brand hover:underline">info@marketingbybesic.com</a>
          </p>
          <div class="flex items-center gap-4">
            <a href="https://www.instagram.com/marketingbybesic" target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-brand transition-colors" aria-label="Instagram">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
            <a href="https://www.tiktok.com/@marketingbybesic" target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-brand transition-colors" aria-label="TikTok">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.75a8.18 8.18 0 0 0 4.76 1.52V6.84a4.84 4.84 0 0 1-1-.15z"/></svg>
            </a>
            <a href="https://www.youtube.com/@marketingbybesic" target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-brand transition-colors" aria-label="YouTube">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
            <a href="https://www.linkedin.com/company/marketing-by-besic/" target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-brand transition-colors" aria-label="LinkedIn">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href="https://x.com/besicmarketing" target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-brand transition-colors" aria-label="X/Twitter">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Cookie Consent Banner -->
    <CookieConsent />

    <!-- Newsletter Modal (deferred - HTML inlined, JS deferred) -->
    <div id="newsletter-modal" class="fixed inset-0 z-[9999] flex items-center justify-center bg-black/80 hidden">
      <div class="bg-[#111111] border border-[#8224e3]/30 rounded-xl p-6 max-w-sm shadow-2xl shadow-brand/20 relative mx-4">
        <button id="newsletter-close" class="absolute top-2 right-2 text-text-secondary hover:text-text-primary transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
        <h3 class="font-heading text-lg font-bold mb-2">Stay Ahead of the Curve</h3>
        <p class="text-text-secondary text-sm mb-4">Get exclusive insights on Neurolinguistic Revenue Architecture delivered to your inbox.</p>
        <form id="newsletter-form" class="flex flex-col gap-3">
          <input type="email" name="email" placeholder="Enter your email" required class="w-full px-4 py-3 bg-bg-primary border border-white/10 rounded-lg text-text-primary placeholder:text-text-secondary focus:outline-none focus:border-brand transition-colors" />
          <button type="submit" class="btn-primary text-sm px-6 py-3">Subscribe</button>
        </form>
        <p id="newsletter-message" class="mt-3 text-sm hidden"></p>
      </div>
    </div>

    <!-- Scripts -->
    <script>
      // Auto-redirect based on browser language on first visit
      (function() {
        const LOCALE_PREF_KEY = 'locale_pref_set';
        
        // Check if user has already set a preference
        if (!localStorage.getItem(LOCALE_PREF_KEY)) {
          const browserLang = navigator.language || (navigator as any).userLanguage;
          const supportedLocales = ['en', 'de', 'fr', 'es', 'it', 'hr'];
          
          // Extract primary language code
          const primaryLang = browserLang.split('-')[0].toLowerCase();
          
          // Get current path
          const currentPath = window.location.pathname;
          
          // Check if we're already on a localized route
          const isOnLocalizedRoute = supportedLocales.some(locale =>
            currentPath.startsWith('/' + locale + '/') || currentPath === '/' + locale
          );
          
          // If browser language matches a supported locale and we're on the default route
          if (supportedLocales.includes(primaryLang) && primaryLang !== 'en' && currentPath === '/') {
            // Mark preference as set to avoid redirect loops
            localStorage.setItem(LOCALE_PREF_KEY, 'true');
            // Redirect to matching locale
            window.location.href = '/' + primaryLang + '/';
          } else if (!isOnLocalizedRoute) {
            // Mark that we've checked preferences
            localStorage.setItem(LOCALE_PREF_KEY, 'true');
          }
        }
      })();

      // Mobile menu toggle
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      if (menuBtn && mobileMenu) {
        menuBtn.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
        });
      }

      // Zagreb time display
      function updateZagrebTime() {
        const el = document.getElementById('zagreb-time');
        if (el) {
          const now = new Date();
          el.textContent = '• ' + now.toLocaleTimeString('en-GB', {
            timeZone: 'Europe/Zagreb',
            hour: '2-digit',
            minute: '2-digit'
          });
        }
      }
      updateZagrebTime();
      setInterval(updateZagrebTime, 60000);
    </script>

    <!-- Global GSAP ScrollTrigger for Image Scroll Reveal (deferred) -->
    <script>
      // Defer GSAP loading until after page load to not block LCP
      window.addEventListener('load', () => {
        setTimeout(() => {
          import('gsap').then(async ({ gsap }) => {
            const { ScrollTrigger } = await import('gsap/ScrollTrigger');
            gsap.registerPlugin(ScrollTrigger);

            // Add lazy loading to all images
            document.querySelectorAll('img').forEach(img => {
              if (!img.hasAttribute('loading')) {
                img.setAttribute('loading', 'lazy');
              }
            });

            // Scroll reveal animation for images
            gsap.utils.toArray('img').forEach((img: any, index: number) => {
              gsap.fromTo(img,
                { opacity: 0, y: 30 },
                {
                  opacity: 1,
                  y: 0,
                  duration: 1,
                  ease: 'power2.out',
                  scrollTrigger: {
                    trigger: img,
                    start: 'top 85%',
                    toggleActions: 'play none none none'
                  },
                  delay: index % 3 * 0.1
                }
              );
            });
          });
        }, 1000);
      });
    </script>

    <!-- Newsletter Modal Script (deferred) -->
    <script>
      window.addEventListener('load', () => {
        setTimeout(() => {
          import('gsap').then(async ({ gsap }) => {
            const modal = document.getElementById('newsletter-modal');
            const modalContent = modal?.querySelector('div');
            const closeBtn = document.getElementById('newsletter-close');
            const form = document.getElementById('newsletter-form');
            const message = document.getElementById('newsletter-message');

            const THIRTY_DAYS = 30 * 24 * 60 * 60 * 1000;
            const CLOSED_KEY = 'newsletter_closed';
            let hasTriggered = false;

            function checkExpiration() {
              const stored = localStorage.getItem(CLOSED_KEY);
              if (stored) {
                const timestamp = parseInt(stored, 10);
                const now = Date.now();
                if (now - timestamp > THIRTY_DAYS) {
                  localStorage.removeItem(CLOSED_KEY);
                  return false;
                }
                return true;
              }
              return false;
            }

            function showModal() {
              if (hasTriggered) return;
              hasTriggered = true;
              modal?.classList.remove('hidden');
              if (modalContent) {
                gsap.fromTo(modalContent,
                  { opacity: 0, y: 50 },
                  { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }
                );
              }
              window.removeEventListener('scroll', onScroll);
            }

            function hideModal() {
              if (modalContent) {
                gsap.to(modalContent, {
                  opacity: 0, y: 50, duration: 0.5, ease: 'power2.in',
                  onComplete: () => { modal?.classList.add('hidden'); }
                });
              }
            }

            function onScroll() {
              if (window.scrollY > 600) { showModal(); }
            }

            if (!checkExpiration()) {
              window.addEventListener('scroll', onScroll);
            }

            closeBtn?.addEventListener('click', () => {
              localStorage.setItem(CLOSED_KEY, Date.now().toString());
              hideModal();
            });

            modal?.addEventListener('click', (e) => {
              if (e.target === modal) {
                localStorage.setItem(CLOSED_KEY, Date.now().toString());
                hideModal();
              }
            });

            form?.addEventListener('submit', async (e) => {
              e.preventDefault();
              const formData = new FormData(form as HTMLFormElement);
              const email = formData.get('email') as string;
              const msgEl = message as HTMLElement;
              try {
                const res = await fetch('/api/subscribe', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ email }),
                });
                const data = await res.json();
                if (res.ok) {
                  window.location.href = '/newsletter-thank-you';
                } else {
                  msgEl.textContent = data.error || 'Something went wrong.';
                  msgEl.className = 'mt-3 text-sm text-brand';
                  msgEl.classList.remove('hidden');
                }
              } catch {
                msgEl.textContent = 'Network error. Please try again.';
                msgEl.className = 'mt-3 text-sm text-brand';
                msgEl.classList.remove('hidden');
              }
            });
          });
        }, 2000);
      });
    </script>
  </body>
</html>
