---
// Language Switcher Component
// Displays a globe icon that opens a dropdown with language options

interface Props {
  mobileOnly?: boolean;
}
const { mobileOnly = false } = Astro.props;

const languages = [
  { code: 'en', label: 'English', flag: '🇬🇧' },
  { code: 'de', label: 'Deutsch', flag: '🇩🇪' },
  { code: 'fr', label: 'Français', flag: '🇫🇷' },
  { code: 'es', label: 'Español', flag: '🇪🇸' },
  { code: 'it', label: 'Italiano', flag: '🇮🇹' },
  { code: 'hr', label: 'Hrvatski', flag: '🇭🇷' },
];

const supportedCodes = languages.map(l => l.code);

// Detect current locale from URL path
const currentPath = Astro.url.pathname;

// Pages that have [lang] equivalents — only these get locale-switched
const localizedPages = ['/', '/about', '/architecture', '/proof', '/contact'];

// Extract locale from path: /en/about -> en, /de/ -> de, / -> en
function detectLocale(path: string): string {
  const segments = path.split('/').filter(Boolean);
  const first = segments[0];
  if (first !== undefined && supportedCodes.includes(first)) {
    return first;
  }
  return 'en';
}

const currentLocale = detectLocale(currentPath);
const currentLang = languages.find(l => l.code === currentLocale) ?? languages[0]!;

// Strip locale prefix from path to get the base page path
function stripLocale(path: string): string {
  const segments = path.split('/').filter(Boolean);
  const first = segments[0];
  if (first !== undefined && supportedCodes.includes(first)) {
    const rest = segments.slice(1).join('/');
    return rest === '' ? '/' : '/' + rest;
  }
  return path;
}

const pagePath = stripLocale(currentPath);

// Check if current page has a localized equivalent
const isLocalizable = localizedPages.includes(pagePath) || pagePath === '/';

// Build localized URL for a given locale
function getLocalizedUrl(locale: string, page: string, canLocalize: boolean): string {
  // If page doesn't have a [lang] equivalent, always return the same path
  if (!canLocalize) return page;
  const cleanPage = page === '' ? '/' : page;
  if (locale === 'en') {
    return cleanPage === '/' ? '/' : `/en${cleanPage}`;
  }
  return cleanPage === '/' ? `/${locale}/` : `/${locale}${cleanPage}`;
}
---

<div class="lang-switcher-wrap" data-mobile-only={mobileOnly ? 'true' : 'false'}>
  <!-- Globe Icon Button -->
  <button
    class="lang-switcher-btn flex items-center gap-2 p-2 text-text-secondary hover:text-text-primary transition-colors"
    aria-label="Select language"
    aria-expanded="false"
  >
    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10" />
      <path d="M2 12h20" />
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
    </svg>
    {!mobileOnly && (
      <span class="hidden sm:inline-flex items-center gap-1 text-sm">
        <span class="text-xs">{currentLang.flag}</span>
        <span>{currentLang.label}</span>
      </span>
    )}
  </button>

  <!-- Dropdown Menu -->
  <div
    class="lang-switcher-dropdown"
    role="menu"
    aria-orientation="vertical"
  >
    <div class="py-2">
      {languages.map((lang) => {
        const localizedHref = getLocalizedUrl(lang.code, pagePath, isLocalizable);
        return (
          <a
            href={localizedHref}
            class={`flex items-center gap-3 px-4 py-2.5 text-sm transition-colors ${
              lang.code === currentLocale
                ? 'bg-brand/10 text-brand'
                : 'text-text-secondary hover:bg-white/5 hover:text-text-primary'
            }`}
            role="menuitem"
            hreflang={lang.code}
          >
            <span class="text-base">{lang.flag}</span>
            <span class="font-medium">{lang.label}</span>
            {lang.code === currentLocale && (
              <svg class="w-4 h-4 ml-auto text-brand" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            )}
          </a>
        );
      })}
    </div>
  </div>
</div>

<style>
  .lang-switcher-wrap {
    position: relative;
  }

  .lang-switcher-dropdown {
    position: absolute;
    right: 0;
    top: 100%;
    margin-top: 0.5rem;
    width: 12rem;
    background-color: #1a1a1a;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem;
    box-shadow: 0 20px 25px -5px rgba(0,0,0,0.5), 0 10px 10px -5px rgba(0,0,0,0.4);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    z-index: 9999;
  }

  .lang-switcher-wrap.open .lang-switcher-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
</style>

<script>
  function initLangSwitchers() {
    const wrappers = document.querySelectorAll<HTMLElement>('.lang-switcher-wrap');

    wrappers.forEach((wrap) => {
      const btn = wrap.querySelector<HTMLButtonElement>('.lang-switcher-btn');
      const dropdown = wrap.querySelector<HTMLElement>('.lang-switcher-dropdown');
      if (!btn || !dropdown) return;

      // Remove any previously attached listeners by cloning
      const newBtn = btn.cloneNode(true) as HTMLButtonElement;
      btn.parentNode!.replaceChild(newBtn, btn);

      newBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const isOpen = wrap.classList.contains('open');

        // Close all other open switchers first
        document.querySelectorAll<HTMLElement>('.lang-switcher-wrap.open').forEach((other) => {
          if (other !== wrap) {
            other.classList.remove('open');
            other.querySelector<HTMLButtonElement>('.lang-switcher-btn')?.setAttribute('aria-expanded', 'false');
          }
        });

        wrap.classList.toggle('open', !isOpen);
        newBtn.setAttribute('aria-expanded', String(!isOpen));
      });
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      document.querySelectorAll<HTMLElement>('.lang-switcher-wrap.open').forEach((wrap) => {
        if (!wrap.contains(e.target as Node)) {
          wrap.classList.remove('open');
          wrap.querySelector<HTMLButtonElement>('.lang-switcher-btn')?.setAttribute('aria-expanded', 'false');
        }
      });
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll<HTMLElement>('.lang-switcher-wrap.open').forEach((wrap) => {
          wrap.classList.remove('open');
          wrap.querySelector<HTMLButtonElement>('.lang-switcher-btn')?.setAttribute('aria-expanded', 'false');
        });
      }
    });
  }

  // Run on initial load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLangSwitchers);
  } else {
    initLangSwitchers();
  }

  // Re-run after Astro view transitions (if used)
  document.addEventListener('astro:page-load', initLangSwitchers);
</script>
