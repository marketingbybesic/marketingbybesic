---
// Cookie Consent Banner Component with 30-Day Tracking
// Uses i18n keys when available, falls back to English
---

<div id="cookie-consent" class="fixed bottom-0 left-0 w-full z-[99999] bg-[#0A0A0A] border-t border-[#8224e3] p-4 hidden">
  <div class="container-custom flex flex-col md:flex-row items-center justify-between gap-4">
    <p class="text-text-secondary text-sm text-center md:text-left" id="cookie-message">
      We use cookies and conversion tracking to architect a better experience. By continuing, you agree to our <a href="/privacy-policy" class="text-brand hover:underline">Privacy Policy</a>.
    </p>
    <div class="flex items-center gap-4">
      <button id="cookie-decline" class="px-6 py-2 border border-white/20 text-text-secondary hover:text-text-primary transition-colors text-sm rounded">
        Decline
      </button>
      <button id="cookie-accept" class="px-6 py-2 bg-[#8224e3] text-white text-sm rounded hover:bg-[#6e1dc4] transition-colors">
        Accept
      </button>
    </div>
  </div>
</div>

<script>
  const { gsap } = await import('gsap');
  const { GTAG_IDS, GTAG_SRC, META_PIXEL_ID } = await import('@/lib/tracking');

  const consentBanner = document.getElementById('cookie-consent') as HTMLElement;
  const acceptBtn = document.getElementById('cookie-accept');
  const declineBtn = document.getElementById('cookie-decline');

  // Localize cookie banner text based on current URL lang
  (function localizeBanner() {
    const path = window.location.pathname;
    const langMatch = path.match(/^\/(de|fr|es|it|hr)\//);
    const lang = langMatch ? langMatch[1] : 'en';

    const translations: Record<string, { message: string; accept: string; decline: string; privacyLabel: string }> = {
      en: { message: 'We use cookies and conversion tracking to architect a better experience. By continuing, you agree to our', accept: 'Accept', decline: 'Decline', privacyLabel: 'Privacy Policy' },
      de: { message: 'Wir verwenden Cookies und Conversion-Tracking, um ein besseres Erlebnis zu gestalten. Durch die Nutzung stimmen Sie unserer', accept: 'Akzeptieren', decline: 'Ablehnen', privacyLabel: 'Datenschutzrichtlinie' },
      fr: { message: 'Nous utilisons des cookies et le suivi des conversions pour concevoir une meilleure experience. En continuant, vous acceptez notre', accept: 'Accepter', decline: 'Refuser', privacyLabel: 'Politique de confidentialite' },
      es: { message: 'Utilizamos cookies y seguimiento de conversiones para disenar una mejor experiencia. Al continuar, acepta nuestra', accept: 'Aceptar', decline: 'Rechazar', privacyLabel: 'Politica de privacidad' },
      it: { message: "Utilizziamo cookie e tracciamento delle conversioni per progettare un'esperienza migliore. Continuando, accetta la nostra", accept: 'Accetta', decline: 'Rifiuta', privacyLabel: 'Informativa sulla privacy' },
      hr: { message: 'Koristimo kolacice i pracenje konverzija za bolje iskustvo. Nastavkom koristenja prihvacate nasu', accept: 'Prihvati', decline: 'Odbij', privacyLabel: 'Politika privatnosti' },
    };

    const t = translations[lang] || translations['en'];
    const base = lang === 'en' ? '' : `/${lang}`;

    const messageEl = document.getElementById('cookie-message');
    if (messageEl) {
      messageEl.innerHTML = `${t.message} <a href="${base}/privacy-policy" class="text-brand hover:underline">${t.privacyLabel}</a>.`;
    }
    if (acceptBtn) acceptBtn.textContent = t.accept;
    if (declineBtn) declineBtn.textContent = t.decline;
  })();

  const THIRTY_DAYS = 30 * 24 * 60 * 60 * 1000;
  // The layouts gate GTM / Meta Pixel / Google Ads on `gdpr_consent === 'accepted'`,
  // so this component must write that exact key — writing a different one meant
  // tags never loaded on a return visit even after the visitor accepted.
  const CONSENT_KEY = 'gdpr_consent';
  const CONSENT_TS_KEY = 'gdpr_consent_at';
  let hasAutoAccepted = false;

  // Check 30-day expiration
  function checkConsent() {
    const choice = localStorage.getItem(CONSENT_KEY);          // 'accepted' | 'declined'
    const at = parseInt(localStorage.getItem(CONSENT_TS_KEY) || '0', 10);
    if (choice && at) {
      if (Date.now() - at > THIRTY_DAYS) {
        // Expired — ask again rather than assuming the old answer still holds.
        localStorage.removeItem(CONSENT_KEY);
        localStorage.removeItem(CONSENT_TS_KEY);
        return false;
      }
      return true;   // a decision exists and is still valid
    }
    return false;    // no decision yet, show banner
  }

  // Accept function (shared by button and scroll auto-accept)
  function acceptConsent() {
    localStorage.setItem(CONSENT_KEY, 'accepted');
    localStorage.setItem(CONSENT_TS_KEY, Date.now().toString());

    // gtag.js (Google Ads + GA4) — IDs live in src/lib/tracking.ts.
    // Loaded here rather than in <head> so it only ever fires after consent.
    (function () {
      const w = window as any;
      if (!GTAG_IDS.length) return;
      if (w.__gtagLoaded) return;               // never inject twice
      w.__gtagLoaded = true;

      const s = document.createElement('script');
      s.async = true;
      s.src = GTAG_SRC;
      document.head.appendChild(s);

      w.dataLayer = w.dataLayer || [];
      w.gtag = function () { w.dataLayer.push(arguments); };
      w.gtag('js', new Date());
      GTAG_IDS.forEach((id: string) => w.gtag('config', id));
    })();

    // Dynamically initialize GTM dataLayer push
    if (typeof (window as any).dataLayer !== 'undefined') {
      (window as any).dataLayer.push({
        event: 'consent_given',
        gtm_start: new Date().getTime()
      });
    }

    // Initialize Google Tag Manager
    (function(w: any, d: Document, s: string, l: string, i: string) {
      w[l] = w[l] || [];
      w[l].push({'gtm.start': new Date().getTime(), event: 'gtm.js'});
      var f = d.getElementsByTagName(s)[0] as HTMLElement,
          j = d.createElement(s) as HTMLScriptElement,
          dl = l != 'dataLayer' ? '&l=' + l : '';
      j.async = true;
      j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
      f.parentNode!.insertBefore(j, f);
    })(window, document, 'script', 'dataLayer', 'GTM-5GL56SKX');

    // Initialize Meta Pixel
    (function(f: Window, b: Document, e: string, v: string, n: any, t: any, s: any) {
      if ((f as any).fbq) return;
      n = (f as any).fbq = function() {
        n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments);
      };
      if (!(f as any)._fbq) (f as any)._fbq = n;
      n.push = n;
      n.loaded = !0;
      n.version = '2.0';
      n.queue = [];
      t = b.createElement(e);
      t.async = !0;
      t.src = v;
      s = b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t, s);
    })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js', undefined, undefined, undefined);

    // Shared event_id so a server-side CAPI event with the same id is
    // deduplicated rather than counted twice.
    const eid = 'pv_' + Date.now() + '_' + Math.random().toString(36).slice(2, 11);
    (window as any).__fbEventId = eid;
    (window as any).fbq('init', META_PIXEL_ID);
    (window as any).fbq('track', 'PageView', {}, { eventID: eid });

    // Smooth fade out animation
    if (consentBanner) {
      gsap.to(consentBanner, {
        opacity: 0,
        y: 20,
        duration: 0.5,
        onComplete: () => {
          consentBanner.style.display = 'none';
        }
      });
    }
  }

  // Initialize
  if (!checkConsent()) {
    consentBanner?.classList.remove('hidden');
  }

  // Accept button
  acceptBtn?.addEventListener('click', () => {
    acceptConsent();
  });

  // Decline button
  declineBtn?.addEventListener('click', () => {
    // Record the refusal explicitly. Previously this stored the same value as
    // Accept, so a declined visitor was indistinguishable from one who agreed.
    localStorage.setItem(CONSENT_KEY, 'declined');
    localStorage.setItem(CONSENT_TS_KEY, Date.now().toString());
    if (consentBanner) {
      gsap.to(consentBanner, {
        opacity: 0,
        y: 20,
        duration: 0.5,
        onComplete: () => {
          consentBanner.style.display = 'none';
        }
      });
    }
  });

  // Auto-accept on scroll (past 600px)
  function onScroll() {
    if (hasAutoAccepted) return;
    if (window.scrollY > 600) {
      hasAutoAccepted = true;
      acceptConsent();
      window.removeEventListener('scroll', onScroll);
    }
  }

  if (!checkConsent()) {
    window.addEventListener('scroll', onScroll);
  }
</script>
