---
// Newsletter Modal Component with Scroll Trigger & 30-Day Tracking
---

<!-- Newsletter Modal Overlay -->
<div id="newsletter-modal" class="fixed inset-0 z-[9999] flex items-center justify-center bg-black/80 hidden">
  <div class="bg-[#111111] border border-[#8224e3]/30 rounded-xl p-6 max-w-sm shadow-2xl shadow-brand/20 relative mx-4">
    <button id="newsletter-close" class="absolute top-2 right-2 text-text-secondary hover:text-text-primary transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <h3 class="font-heading text-lg font-bold mb-2">Stay Ahead of the Curve</h3>
    <p class="text-text-secondary text-sm mb-4">Get exclusive insights on Neurolinguistic Revenue Architecture delivered to your inbox.</p>
    <form id="newsletter-form" class="flex flex-col gap-3">
      <input
        type="email"
        name="email"
        placeholder="Enter your email"
        required
        class="w-full px-4 py-3 bg-bg-primary border border-white/10 rounded-lg text-text-primary placeholder:text-text-secondary focus:outline-none focus:border-brand transition-colors"
      />
      <button type="submit" class="btn-primary text-sm px-6 py-3">
        Subscribe
      </button>
    </form>
    <p id="newsletter-message" class="mt-3 text-sm hidden"></p>
  </div>
</div>

<script>
  const { gsap } = await import('gsap');

  const modal = document.getElementById('newsletter-modal');
  const modalContent = modal?.querySelector('div') as HTMLElement | null;
  const closeBtn = document.getElementById('newsletter-close');
  const form = document.getElementById('newsletter-form');
  const message = document.getElementById('newsletter-message');

  const THIRTY_DAYS = 30 * 24 * 60 * 60 * 1000;
  const CLOSED_KEY = 'newsletter_closed';
  let hasTriggered = false;

  // Check 30-day expiration
  function checkExpiration() {
    const stored = localStorage.getItem(CLOSED_KEY);
    if (stored) {
      const timestamp = parseInt(stored, 10);
      const now = Date.now();
      if (now - timestamp > THIRTY_DAYS) {
        // Expired, clear it
        localStorage.removeItem(CLOSED_KEY);
        return false;
      }
      // Still valid, do not show
      return true;
    }
    return false;
  }

  // Show modal with smooth GSAP animation
  function showModal() {
    if (hasTriggered) return;
    hasTriggered = true;
    modal?.classList.remove('hidden');
    
    // Smooth GSAP animation
    if (modalContent) {
      gsap.fromTo(modalContent,
        { opacity: 0, y: 50 },
        { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }
      );
    }
    
    // Remove scroll listener after first trigger
    window.removeEventListener('scroll', onScroll);
  }

  // Hide modal with smooth animation
  function hideModal() {
    if (modalContent) {
      gsap.to(modalContent, {
        opacity: 0,
        y: 50,
        duration: 0.5,
        ease: 'power2.in',
        onComplete: () => {
          modal?.classList.add('hidden');
        }
      });
    }
  }

  // Scroll listener
  function onScroll() {
    if (window.scrollY > 600) {
      showModal();
    }
  }

  // Initialize
  if (!checkExpiration()) {
    window.addEventListener('scroll', onScroll);
  }

  // Close button
  closeBtn?.addEventListener('click', () => {
    localStorage.setItem(CLOSED_KEY, Date.now().toString());
    hideModal();
  });

  // Close on overlay click (outside modal content)
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      localStorage.setItem(CLOSED_KEY, Date.now().toString());
      hideModal();
    }
  });

  // Form submission
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formEl = form as HTMLFormElement;
    const formData = new FormData(formEl);
    const email = formData.get('email') as string;
    const msgEl = message as HTMLElement;

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      const data = await res.json();

      if (res.ok) {
        // Redirect to thank you page
        window.location.href = '/newsletter-thank-you';
      } else {
        msgEl.textContent = data.error || 'Something went wrong.';
        msgEl.className = 'mt-3 text-sm text-brand';
        msgEl.classList.remove('hidden');
      }
    } catch {
      msgEl.textContent = 'Network error. Please try again.';
      msgEl.className = 'mt-3 text-sm text-brand';
      msgEl.classList.remove('hidden');
    }
  });
</script>
