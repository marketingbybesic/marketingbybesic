# SendFox API Configuration
# Get your token from: https://sendfox.com/settings/api
SENDFOX_API_TOKEN=your_token_here

# TinaCMS Configuration
# Get these from: https://tina.io -> Your Project -> Settings -> API Tokens
NEXT_PUBLIC_TINA_CLIENT_ID=your_client_id_here
TINA_TOKEN=your_content_token_here
